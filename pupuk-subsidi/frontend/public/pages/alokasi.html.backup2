<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Alokasi — SiPupuk</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
</head>
<body class="bg-gray-50 flex">
  <div id="navbar"></div>
  <main class="flex-1 p-8">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl font-bold text-gray-800">Manajemen Alokasi</h1>
          <p class="text-gray-500 text-sm mt-1">Alokasikan pupuk dari kuota ke kelompok tani</p>
        </div>
        <button onclick="openModal()"
          class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2.5 rounded-xl flex items-center gap-2 transition">
          <i class="fas fa-plus"></i> Buat Alokasi
        </button>
      </div>

      <!-- Filter -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 mb-6 flex gap-4 flex-wrap">
        <select id="filterStatus" class="border border-gray-200 rounded-xl px-3 py-2 text-sm">
          <option value="">Semua Status</option>
          <option value="pending">Pending</option>
          <option value="disetujui">Disetujui</option>
          <option value="ditolak">Ditolak</option>
        </select>
        <button onclick="loadAlokasi()"
          class="bg-green-50 text-green-700 border border-green-200 px-4 py-2 rounded-xl text-sm font-medium hover:bg-green-100 transition">
          <i class="fas fa-search"></i> Filter
        </button>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Distributor</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Kelompok Tani</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Jenis Pupuk</th>
                <th class="text-right px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Jumlah (kg)</th>
                <th class="text-left px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Tgl Alokasi</th>
                <th class="text-center px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Status</th>
                <th class="text-center px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Aksi</th>
              </tr>
            </thead>
            <tbody id="alokasiBody" class="divide-y divide-gray-50"></tbody>
          </table>
        </div>
        <div id="alokasiEmpty" class="hidden py-12 text-center text-gray-400">
          <i class="fas fa-tasks text-3xl mb-3"></i>
          <p>Belum ada data alokasi</p>
        </div>
      </div>
    </div>
  </main>

  <!-- Modal Buat Alokasi -->
  <div id="modal" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-semibold text-gray-800 text-lg">Buat Alokasi Pupuk</h3>
        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
      </div>
      <div class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Kuota</label>
          <select id="fKuota" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-green-500 focus:outline-none">
            <option value="">Pilih Kuota</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Distributor</label>
          <select id="fDistributor" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-green-500 focus:outline-none">
            <option value="">Pilih Distributor</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Kelompok Tani</label>
          <select id="fKelompok" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-green-500 focus:outline-none">
            <option value="">Pilih Kelompok Tani</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Jenis Pupuk</label>
          <select id="fPupuk" class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-green-500 focus:outline-none">
            <option value="Urea">Urea</option>
            <option value="NPK">NPK</option>
            <option value="SP36">SP36</option>
            <option value="ZA">ZA</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Jumlah (kg)</label>
          <input type="number" id="fJumlah" placeholder="500"
            class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-green-500 focus:outline-none"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Tanggal Alokasi</label>
          <input type="date" id="fTanggal"
            class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-green-500 focus:outline-none"/>
        </div>
        <button onclick="save()"
          class="w-full bg-green-600 hover:bg-green-700 text-white font-medium py-2.5 rounded-xl transition text-sm">
          Buat Alokasi
        </button>
      </div>
    </div>
  </div>

  <div id="toast" class="hidden fixed bottom-4 right-4 px-5 py-3 rounded-xl text-white text-sm font-medium shadow-lg z-50"></div>
  <script src="/assets/js/api.js"></script>
  <script src="/assets/js/auth.js"></script>
  <script>
    requireAuth();
    document.getElementById('navbar').innerHTML = renderNavbar('alokasi');

    const loadAlokasi = async () => {
      const status = document.getElementById('filterStatus').value;
      const params = status ? `?status=${status}` : '?';
      const res = await api.getAlokasi(params);
      const tbody = document.getElementById('alokasiBody');
      const empty = document.getElementById('alokasiEmpty');
      if (res.success && res.data.length) {
        empty.classList.add('hidden');
        tbody.innerHTML = res.data.map(a => `
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 text-gray-600">${a.distributor_nama || '-'}</td>
            <td class="px-6 py-4 font-medium text-gray-800">${a.kelompok_tani_nama || '-'}</td>
            <td class="px-6 py-4"><span class="px-2.5 py-1 bg-green-50 text-green-700 rounded-lg text-xs font-medium">${a.jenis_pupuk}</span></td>
            <td class="px-6 py-4 text-right font-semibold text-gray-800">${formatNumber(a.jumlah_kg)}</td>
            <td class="px-6 py-4 text-gray-600">${formatDate(a.tanggal_alokasi)}</td>
            <td class="px-6 py-4 text-center">
              <span class="px-2.5 py-1 rounded-full text-xs font-medium ${badgeStatus(a.status)}">${a.status}</span>
            </td>
          </tr>`).join('');
      } else { tbody.innerHTML = ''; empty.classList.remove('hidden'); }
    };

    const openModal = async () => {
      const [kuotaRes, distRes, ktRes] = await Promise.all([
        api.getKuota('?'), api.getDistributor(), api.getKelompokTani()
      ]);
      const selK = document.getElementById('fKuota');
      const selD = document.getElementById('fDistributor');
      const selKT = document.getElementById('fKelompok');
      selK.innerHTML = '<option value="">Pilih Kuota</option>';
      selD.innerHTML = '<option value="">Pilih Distributor</option>';
      selKT.innerHTML = '<option value="">Pilih Kelompok Tani</option>';
      if (kuotaRes.success) kuotaRes.data.forEach(k => {
        selK.innerHTML += `<option value="${k.id}">${k.wilayah_nama} - ${k.jenis_pupuk} (Sisa: ${formatNumber(k.sisa_kuota_kg)}kg)</option>`;
      });
      if (distRes.success) distRes.data.forEach(d => {
        selD.innerHTML += `<option value="${d.id}">${d.nama}</option>`;
      });
      if (ktRes.success) ktRes.data.forEach(k => {
        selKT.innerHTML += `<option value="${k.id}">${k.nama}</option>`;
      });
      document.getElementById('fTanggal').value = new Date().toISOString().split('T')[0];
      document.getElementById('modal').classList.remove('hidden');
    };
    const closeModal = () => document.getElementById('modal').classList.add('hidden');

    const save = async () => {
      const kuota_id = document.getElementById('fKuota').value;
      const distributor_id = document.getElementById('fDistributor').value;
      const kelompok_id = document.getElementById('fKelompok').value;
      const jenis_pupuk = document.getElementById('fPupuk').value;
      const jumlah_kg = parseFloat(document.getElementById('fJumlah').value);
      const tanggal_alokasi = document.getElementById('fTanggal').value;
      if (!kuota_id || !distributor_id || !kelompok_id || !jumlah_kg) {
        return showToast('Semua field wajib diisi', 'error');
      }
      const res = await api.createAlokasi({ kuota_id, distributor_id, kelompok_id, jenis_pupuk, jumlah_kg, tanggal_alokasi });
      if (res.success) { showToast(res.message); closeModal(); loadAlokasi(); }
      else showToast(res.message, 'error');
    };

    loadAlokasi();
  </script>
</body>
</html>
